# 8.1. Создаём словарь: ключ — страна, значение — столица
capitals = {
    "Россия": "Москва",
    "Франция": "Париж",
    "Германия": "Берлин",
    "Италия": "Рим",
    "Китай": "Пекин",
    "Япония": "Токио"
}

# a) Выводим все пары ключ-значение
print("----- а) Все пары страна-столица -----")
for country, city in capitals.items():
    # .items() возвращает пары (ключ, значение)
    print(f"{country} — {city}")

# b) Выводим столицу для определённой страны (запрос у пользователя)
print("\n----- б) Поиск столицы -----")
requested_country = input("Введите название страны: ")

# Используем метод .get() — он вернёт значение по ключу или None, если ключа нет
capital = capitals.get(requested_country)
if capital:
    print(f"Столица {requested_country} — {capital}")
else:
    print("Извините, такой страны нет в словаре.")

# c) Сортировка по названиям стран и вывод
print("\n----- в) Словарь в алфавитном порядке стран -----")
# Получаем список ключей (стран) и сортируем его
sorted_countries = sorted(capitals.keys())

for country in sorted_countries:
    # Выводим в формате "страна: столица"
    print(f"{country}: {capitals[country]}")


# 8.2. Словарь соответствия "буква → очки"
points = {
    'А': 1, 'В': 1, 'Е': 1, 'И': 1, 'Н': 1, 'О': 1, 'Р': 1, 'С': 1, 'Т': 1,
    'Д': 2, 'К': 2, 'Л': 2, 'М': 2, 'П': 2, 'У': 2,
    'Б': 3, 'Г': 3, 'Ё': 3, 'Ь': 3, 'Я': 3,
    'Й': 4, 'Ы': 4,
    'Ж': 5, 'З': 5, 'Х': 5, 'Ц': 5, 'Ч': 5,
    'Ш': 8, 'Э': 8, 'Ю': 8,
    'Ф': 10, 'Щ': 10, 'Ъ': 10
}

# Запрашиваем слово у пользователя
word = input("Введите слово для подсчёта очков: ")

# Приводим к верхнему регистру, так как в словаре все буквы заглавные
word = word.upper()

total_score = 0  # переменная для накопления суммы очков

# Проходим по каждой букве в слове
for letter in word:
    # Если буква есть в словаре очков, прибавляем её стоимость
    if letter in points:
        total_score += points[letter]
    else:
        # На случай, если попадётся символ не из русского алфавита (пробел, дефис и т.д.)
        print(f"Символ '{letter}' не найден в таблице очков, пропускаем.")

print(f"Стоимость слова '{word}': {total_score} очков.")

# 8.3. Множества языков, которыми владеют студенты

# Представим данные в виде словаря: ключ — имя студента, значение — множество языков
students = {
    "Анна": {"русский", "английский", "французский"},
    "Борис": {"русский", "немецкий", "китайский"},
    "Виктор": {"русский", "испанский", "китайский"},
    "Галина": {"русский", "английский", "итальянский"},
    "Дмитрий": {"русский", "китайский", "японский"}
}

# 1) Сколько различных языков знают студенты?
# Создаём пустое множество для объединения всех языков
all_languages = set()

# Проходим по каждому студенту
for name, langs in students.items():
    # Объединяем множество языков текущего студента с общим множеством
    all_languages = all_languages.union(langs)

# Можно было также использовать оператор | в цикле или метод .update()

print("----- Все различные языки, которые знают студенты -----")
print(f"Количество различных языков: {len(all_languages)}")

# Сортируем и выводим список языков
sorted_languages = sorted(all_languages)
print("Список языков в алфавитном порядке:")
for lang in sorted_languages:
    print(f"  - {lang}")

# 2) Студенты, знающие китайский язык
print("\n----- Студенты, знающие китайский язык -----")
chinese_speakers = []  # список для имён

for name, langs in students.items():
    if "китайский" in langs:
        chinese_speakers.append(name)

if chinese_speakers:
    print("Китайский знают:")
    for student in chinese_speakers:
        print(f"  - {student}")
else:
    print("Никто из студентов не знает китайского.")
